---
import LogoMark from '../assets/pta-logo.svg';
import '../styles/global.css';

const links = [
  { href: '/specification/', label: '标准', description: '阅读 PTA 的核心定义与约束。' },
  { href: '/guide/', label: '指南', description: '了解如何在项目中应用 PTA。' },
];
---

<html lang="zh-CN" class="bg-background text-foreground">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="PTA（Project Truth Architecture / 项目真相架构）标准文档。"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>PTA</title>
  </head>
  <body class="min-h-svh bg-background text-foreground antialiased">
    <main class="grid min-h-svh place-items-center px-6 py-12 sm:px-8">
      <section class="w-full max-w-3xl" aria-labelledby="title">
        <p class="mb-5 font-heading text-sm font-semibold uppercase text-muted-foreground">
          Project Truth Architecture
        </p>
        <div class="flex items-center gap-5 sm:gap-8">
          <LogoMark
            class="size-20 shrink-0 drop-shadow-lg sm:size-24 lg:size-28"
            aria-hidden="true"
            focusable="false"
          />
          <h1 id="title" class="font-heading text-7xl leading-none font-bold sm:text-8xl lg:text-9xl">
            PTA
          </h1>
        </div>
        <p class="mt-7 mb-10 max-w-xl font-body text-xl leading-8 text-foreground/80 sm:text-2xl sm:leading-9">
          项目真相架构的标准文档入口。
        </p>
        <nav class="grid gap-4 sm:grid-cols-2" aria-label="主要入口">
          {
            links.map((link) => (
              <a
                class="grid min-h-28 gap-2 rounded-lg border border-border bg-card/75 p-5 text-card-foreground no-underline transition-colors hover:border-ring hover:bg-card focus-visible:ring-3 focus-visible:ring-ring/30 focus-visible:outline-none"
                href={link.href}
              >
                <span class="font-heading text-xl font-bold">{link.label}</span>
                <small class="font-body text-sm leading-6 text-muted-foreground sm:text-base">
                  {link.description}
                </small>
              </a>
            ))
          }
        </nav>
      </section>
    </main>
  </body>
</html>
