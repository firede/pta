---
const links = [
	{ href: '/specification/', label: '标准', description: '阅读 PTA 的核心定义与约束。' },
	{ href: '/guide/', label: '指南', description: '了解如何在项目中应用 PTA。' },
];
---

<html lang="zh-CN">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<meta
			name="description"
			content="PTA（Project Truth Architecture / 项目真相架构）标准文档。"
		/>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>PTA</title>
	</head>
	<body>
		<main>
			<section class="hero" aria-labelledby="title">
				<p class="eyebrow">Project Truth Architecture</p>
				<h1 id="title">PTA</h1>
				<p class="lead">项目真相架构的标准文档入口。</p>
				<nav aria-label="主要入口">
					{
						links.map((link) => (
							<a href={link.href}>
								<span>{link.label}</span>
								<small>{link.description}</small>
							</a>
						))
					}
				</nav>
			</section>
		</main>
	</body>
</html>

<style>
	:root {
		color-scheme: light dark;
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
		background: #f7f7f4;
		color: #1f2428;
	}

	body {
		margin: 0;
		min-height: 100vh;
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.74), rgba(247, 247, 244, 0.92)),
			#f7f7f4;
	}

	main {
		display: grid;
		min-height: 100vh;
		padding: 48px 24px;
		place-items: center;
		box-sizing: border-box;
	}

	.hero {
		width: min(100%, 760px);
	}

	.eyebrow {
		margin: 0 0 18px;
		color: #5b6872;
		font-size: 14px;
		font-weight: 650;
		letter-spacing: 0;
		text-transform: uppercase;
	}

	h1 {
		margin: 0;
		font-size: clamp(64px, 14vw, 156px);
		line-height: 0.9;
		letter-spacing: 0;
	}

	.lead {
		max-width: 560px;
		margin: 28px 0 42px;
		color: #39424a;
		font-size: 22px;
		line-height: 1.55;
	}

	nav {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 14px;
	}

	a {
		display: grid;
		gap: 8px;
		min-height: 108px;
		padding: 22px;
		border: 1px solid #cfd4d8;
		border-radius: 8px;
		color: inherit;
		text-decoration: none;
		background: rgba(255, 255, 255, 0.72);
		box-sizing: border-box;
	}

	a:hover {
		border-color: #7f8b93;
		background: #ffffff;
	}

	span {
		font-size: 20px;
		font-weight: 700;
	}

	small {
		color: #5b6872;
		font-size: 15px;
		line-height: 1.5;
	}

	@media (max-width: 640px) {
		main {
			padding: 32px 18px;
			place-items: start;
			align-items: center;
		}

		nav {
			grid-template-columns: 1fr;
		}
	}

	@media (prefers-color-scheme: dark) {
		:root {
			background: #111416;
			color: #f0f2f2;
		}

		body {
			background:
				linear-gradient(180deg, rgba(24, 28, 31, 0.82), rgba(17, 20, 22, 0.98)),
				#111416;
		}

		.eyebrow,
		small {
			color: #9aa6ad;
		}

		.lead {
			color: #ccd3d7;
		}

		a {
			border-color: #343c42;
			background: rgba(31, 36, 40, 0.78);
		}

		a:hover {
			border-color: #68757d;
			background: #252b2f;
		}
	}
</style>
