---
import ptaLogo from '@/assets/pta-logo.svg?raw';

import CanonEntries from '@/components/docs/CanonEntries.astro';
import { getCanon } from '@/lib/canon';

interface Cta {
  label: string;
  href: string;
  primary?: boolean;
}

interface VolumeIntro {
  question: string;
  blurb: string;
}

interface Lineage {
  before?: string;
  title: string;
  href: string;
  after: string;
}

interface Props {
  /** 竖排题字（汉语区划用），拉丁语言用横排 */
  vertical?: boolean;
  title: string;
  epigraph: string;
  epigraphSource: string;
  /** 题记的译文说明（非汉语区划用） */
  epigraphNote?: string;
  intro: readonly string[];
  ctas: readonly Cta[];
  /** 三卷的引语与简述，键为卷标识 */
  volumes: Record<'argument' | 'specification' | 'guide', VolumeIntro>;
  /** 渊源牌记：指向《人类带宽设计》总纲 */
  lineage?: Lineage;
  footnote: string;
}

const {
  vertical = false,
  title,
  epigraph,
  epigraphSource,
  epigraphNote,
  intro,
  ctas,
  volumes,
  lineage,
  footnote,
} = Astro.props;

const { locale } = Astro.locals.starlightRoute;
const canon = await getCanon(locale);
const totalLabel = Astro.locals.t('canon.total');
---

<div class:list={['landing', 'not-content', { 'landing-vertical': vertical }]}>
  <section class="cover" aria-label={title}>
    <div class="cover-script">
      <h1 class="cover-title">{title}</h1>
      <div class="cover-side">
        <p class="cover-epigraph">
          {epigraph}
          <cite class="cover-cite">{epigraphSource}</cite>
        </p>
        <span class="cover-seal" set:html={ptaLogo} />
      </div>
    </div>
    <div class="cover-body">
      {epigraphNote && <p class="cover-note">{epigraphNote}</p>}
      <div class="cover-lede">
        {intro.map((paragraph) => <p>{paragraph}</p>)}
      </div>
      <div class="cover-ctas">
        {
          ctas.map((cta) => (
            <a class:list={['cta', { 'cta-primary': cta.primary }]} href={cta.href}>
              {cta.label}
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="total" aria-label={totalLabel}>
    <header class="total-head" data-reveal>
      <span class="total-marker" aria-hidden="true"></span>
      <h2 class="total-title">{totalLabel}</h2>
    </header>
    {
      canon.map((volume) => (
        <section class="total-volume" data-reveal>
          <header class="volume-head">
            <p class="volume-name">
              <span class="volume-ordinal">{volume.ordinal}</span>
              <span class="volume-label">{volume.label}</span>
            </p>
            <p class="volume-question">{volumes[volume.key].question}</p>
            <p class="volume-blurb">{volumes[volume.key].blurb}</p>
          </header>
          <CanonEntries volume={volume.key} />
        </section>
      ))
    }
  </section>

  <footer class="landing-colophon" data-reveal>
    {
      lineage && (
        <p class="colophon-lineage">
          {lineage.before}<a href={lineage.href}><cite>{lineage.title}</cite></a>{lineage.after}
        </p>
      )
    }
    <p class="colophon-note">{footnote}</p>
  </footer>
</div>

<script>
  // 显影：总目与牌记随滚动渐次浮现，一次性，不往复。
  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          observer.unobserve(entry.target);
        }
      }
    },
    { rootMargin: '0px 0px -8% 0px', threshold: 0.05 },
  );
  for (const element of document.querySelectorAll('[data-reveal]')) observer.observe(element);
</script>

<style is:global>
  main:has(.landing) {
    --sl-content-width: 62rem;
  }

  main:has(.landing) .sl-markdown-content {
    text-align: start;
  }

  /* 首页题字自任 h1，隐去 Starlight 默认页标题面板 */
  main:has(.landing) .content-panel:has(h1[id='_top']) {
    display: none;
  }

  .landing .cover-seal svg {
    inline-size: 2.5rem;
    block-size: 2.5rem;
  }

  .landing .cover-seal .pta-logo__ground {
    fill: var(--color-cinnabar-500);
  }

  .landing .cover-seal .pta-logo__mark {
    fill: var(--color-paper-raised);
  }

  :root[data-theme='dark'] .landing .cover-seal .pta-logo__ground {
    fill: var(--color-cinnabar-500);
  }

  :root[data-theme='dark'] .landing .cover-seal .pta-logo__mark {
    fill: oklch(0.215 0.013 168);
  }

  /* 显影基态与终态 */
  [data-reveal] {
    opacity: 0;
    transform: translateY(12px);
    transition:
      opacity 0.55s ease,
      transform 0.55s cubic-bezier(0.22, 0.61, 0.36, 1);
  }

  [data-reveal].revealed {
    opacity: 1;
    transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    [data-reveal] {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<style>
  .landing {
    display: flex;
    flex-direction: column;
  }

  /* ── 封面 ─────────────────────────────── */

  .cover {
    min-height: calc(100svh - var(--sl-nav-height) - 3rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: clamp(2rem, 5vh, 3.5rem);
    padding-block: clamp(2rem, 6vh, 4rem);
  }

  .cover-script {
    display: flex;
    flex-direction: column-reverse;
    align-items: center;
    gap: 1.5rem;
  }

  .cover-body {
    display: flex;
    flex-direction: column;
    align-items: center;
    max-inline-size: 34em;
  }

  .cover-title {
    margin: 0;
    font-weight: 750;
    font-size: clamp(2.6rem, 1.9rem + 3vw, 3.9rem);
    line-height: 1.12;
    color: var(--sl-color-white);
    text-align: center;
  }

  .cover-epigraph {
    margin: 0;
    font-size: 1rem;
    letter-spacing: 0.28em;
    color: var(--sl-color-gray-3);
  }

  .cover-cite {
    font-style: normal;
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    color: var(--sl-color-gray-3);
  }

  .landing:not(.landing-vertical) .cover-side {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
  }

  .landing:not(.landing-vertical) .cover-cite {
    display: block;
    letter-spacing: 0.02em;
  }

  .landing:not(.landing-vertical) .cover-cite::before {
    content: '— ';
  }

  .landing:not(.landing-vertical) .cover-seal {
    display: none;
  }

  .cover-note {
    margin: 0 0 1.5rem;
    max-width: 30em;
    font-size: 0.88rem;
    line-height: 1.7;
    color: var(--sl-color-gray-3);
    text-align: center;
  }

  .cover-lede {
    display: flex;
    flex-direction: column;
    gap: 1em;
  }

  .cover-lede p {
    margin: 0;
    font-size: 1.0625rem;
    line-height: 1.95;
  }

  .cover-ctas {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.875rem;
    margin-block-start: 2.25rem;
  }

  .cta {
    font-family: var(--font-ui);
    font-size: 0.92rem;
    font-weight: 500;
    text-decoration: none;
    color: var(--sl-color-white);
    border: 1px solid var(--sl-color-gray-4);
    border-radius: 2px;
    padding: 0.65em 1.6em;
    transition:
      color 0.15s,
      border-color 0.15s,
      background-color 0.15s;
  }

  .cta:hover {
    border-color: var(--sl-color-white);
  }

  .cta-primary {
    background-color: var(--color-cinnabar-500);
    border-color: var(--color-cinnabar-500);
    color: var(--color-paper-raised);
  }

  .cta-primary:hover {
    background-color: var(--color-cinnabar-600);
    border-color: var(--color-cinnabar-600);
  }

  :root[data-theme='dark'] .cta-primary {
    background-color: var(--color-cinnabar-400);
    border-color: var(--color-cinnabar-400);
    color: oklch(0.215 0.013 168);
  }

  :root[data-theme='dark'] .cta-primary:hover {
    background-color: var(--color-cinnabar-300);
    border-color: var(--color-cinnabar-300);
  }

  /* 竖排封面：题字居右，界行相隔，导语居左；印作落款 */
  .landing-vertical .cover {
    flex-direction: row-reverse;
    align-items: center;
    justify-content: space-between;
    gap: clamp(2.5rem, 6vw, 5rem);
  }

  .landing-vertical .cover-script {
    writing-mode: vertical-rl;
    flex-direction: column;
    align-items: stretch;
    gap: clamp(1.4rem, 4vw, 2.4rem);
    padding-inline-start: clamp(1.25rem, 3vw, 2.25rem);
    border-inline-start: 1px solid var(--sl-color-gray-5);
  }

  .landing-vertical .cover-title {
    font-size: clamp(2.9rem, 2rem + 3vw, 4.1rem);
    line-height: 1;
    letter-spacing: 0.14em;
    text-align: start;
  }

  .landing-vertical .cover-side {
    display: flex;
    justify-content: space-between;
    gap: 2rem;
  }

  .landing-vertical .cover-epigraph {
    margin: 0;
    letter-spacing: 0.4em;
  }

  .landing-vertical .cover-cite {
    display: block;
    margin-block-start: 1em;
    margin-inline-start: 4.5em;
  }

  .landing-vertical .cover-body {
    align-items: flex-start;
  }

  .landing-vertical .cover-note {
    text-align: start;
  }

  .landing-vertical .cover-ctas {
    justify-content: flex-start;
  }

  /* 封面入场：墨影渐次显影，一次编排 */
  @keyframes cover-rise {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  .cover-script {
    animation: cover-rise 0.7s cubic-bezier(0.22, 0.61, 0.36, 1) 0.05s backwards;
  }

  .cover-body {
    animation: cover-rise 0.7s cubic-bezier(0.22, 0.61, 0.36, 1) 0.3s backwards;
  }

  @media (prefers-reduced-motion: reduce) {
    .cover-script,
    .cover-body {
      animation: none;
    }
  }

  /* ── 总目 ─────────────────────────────── */

  .total {
    margin-block-start: clamp(2rem, 6vh, 4rem);
  }

  .total-head {
    display: flex;
    align-items: center;
    gap: 0.8em;
    padding-block-end: 0.9rem;
    border-block-end: 1px solid var(--sl-color-gray-5);
  }

  .total-marker {
    inline-size: 0.55em;
    block-size: 0.55em;
    background: var(--color-cinnabar-500);
  }

  :root[data-theme='dark'] .total-marker {
    background: var(--color-cinnabar-400);
  }

  .total-title {
    margin: 0;
    font-family: var(--font-ui);
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.28em;
    color: var(--sl-color-gray-3);
  }

  .total-volume {
    margin-block-start: clamp(2rem, 5vh, 3.25rem);
  }

  .volume-head {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: baseline;
    gap: 0.2rem 1.5rem;
  }

  .volume-name {
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: 0.7em;
  }

  .volume-ordinal {
    font-size: 0.85rem;
    color: var(--color-cinnabar-500);
  }

  :root[data-theme='dark'] .volume-ordinal {
    color: var(--color-cinnabar-400);
  }

  .volume-label {
    font-size: 1.45rem;
    font-weight: 700;
    color: var(--sl-color-white);
  }

  .volume-question {
    margin: 0;
    font-size: 0.95rem;
    color: var(--sl-color-gray-2);
  }

  .volume-blurb {
    grid-column: 1 / -1;
    margin: 0.35rem 0 0;
    font-size: 0.9rem;
    line-height: 1.75;
    color: var(--sl-color-gray-3);
  }

  /* ── 牌记 ─────────────────────────────── */

  .landing-colophon {
    margin-block: clamp(3.5rem, 9vh, 5.5rem) 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.55rem;
    text-align: center;
  }

  .colophon-lineage {
    margin: 0;
    font-size: 0.9rem;
    letter-spacing: 0.02em;
    color: var(--sl-color-gray-2);
  }

  .colophon-lineage a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 0.3em;
    text-decoration-color: var(--sl-color-gray-4);
    transition:
      color 0.15s,
      text-decoration-color 0.15s;
  }

  .colophon-lineage a:hover {
    color: var(--sl-color-accent);
    text-decoration-color: currentColor;
  }

  .colophon-lineage cite {
    font-style: italic;
  }

  :global(:root[lang^='zh']) .colophon-lineage cite {
    font-style: normal;
  }

  .colophon-note {
    margin: 0;
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    color: var(--sl-color-gray-3);
  }

  /* ── 窄屏 ─────────────────────────────── */

  @media (max-width: 50rem) {
    .cover {
      min-height: auto;
    }

    .landing-vertical .cover {
      flex-direction: column;
      gap: 2.5rem;
    }

    .landing-vertical .cover-body {
      align-items: center;
    }

    .landing-vertical .cover-ctas {
      justify-content: center;
    }

    .volume-head {
      grid-template-columns: 1fr;
    }
  }
</style>
