---
import Default from '@astrojs/starlight/components/PageTitle.astro';

import { type GlobalMessageKey, globalMessages } from '@/data/i18n';
import { getLanguageFromLocale } from '@/lib/i18n';

const { id, locale } = Astro.locals.starlightRoute;

/** 文体眉标：从条目路径首段识别所属文体 */
const genreKeys: Record<string, GlobalMessageKey> = {
  argument: 'arguments',
  specification: 'specification',
  guide: 'guide',
  topic: 'topics',
};

const segments = id.split('/');
const genreSegment = segments[0] === locale ? segments[1] : segments[0];
const genreKey = genreSegment ? genreKeys[genreSegment] : undefined;
const genre = genreKey ? globalMessages[getLanguageFromLocale(locale)][genreKey] : undefined;
---

{genre && <p class="genre-eyebrow">{genre}</p>}
<Default><slot /></Default>

<style>
  .genre-eyebrow {
    margin: 0 0 0.9rem;
    font-family: var(--font-heading);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.22em;
    color: var(--sl-color-gray-3);
  }
</style>
