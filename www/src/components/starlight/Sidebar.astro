---
import MobileMenuFooter from '@astrojs/starlight/components/MobileMenuFooter.astro';

const { sidebar } = Astro.locals.starlightRoute;

type Entry = (typeof sidebar)[number];
type LinkEntry = Extract<Entry, { type: 'link' }>;

function hasCurrent(entry: Entry): boolean {
  return entry.type === 'link' ? entry.isCurrent : entry.entries.some(hasCurrent);
}

function firstHref(entry: Entry): string {
  if (entry.type === 'link') return entry.href;
  const [first] = entry.entries;
  return first ? firstHref(first) : '#';
}

function linksOf(entry: Entry): LinkEntry[] {
  return entry.type === 'link' ? [entry] : entry.entries.flatMap(linksOf);
}

const currentSection = sidebar.find(hasCurrent);
const pages = currentSection?.type === 'group' ? linksOf(currentSection) : [];
---

<nav class="section-nav" aria-label={Astro.locals.t('sectionNav.accessibleLabel')}>
  <ul>
    {
      sidebar.map((section) => (
        <li>
          <a
            href={firstHref(section)}
            class:list={['section-link', { current: section === currentSection }]}
            aria-current={section === currentSection ? 'true' : undefined}
          >
            {section.label}
          </a>
        </li>
      ))
    }
  </ul>
</nav>

{
  pages.length > 0 && (
    <ul class="section-pages">
      {pages.map((page) => (
        <li>
          <a href={page.href} aria-current={page.isCurrent ? 'page' : undefined}>
            {page.label}
          </a>
        </li>
      ))}
    </ul>
  )
}

<div class="md:sl-hidden">
  <MobileMenuFooter />
</div>

<style>
  .section-nav ul {
    list-style: none;
    margin: 0;
    padding: 0.3rem;
    display: flex;
    flex-direction: column;
    gap: 2px;
    background-color: var(--sl-color-gray-6);
    border-radius: 0.5rem;
  }

  .section-link {
    display: block;
    padding: 0.45em 0.75em;
    font-size: 0.9rem;
    font-weight: 500;
    line-height: 1.5;
    text-decoration: none;
    color: var(--sl-color-gray-2);
    border-radius: 0.35rem;
    transition: color 0.15s;
  }

  .section-link:hover {
    color: var(--sl-color-white);
  }

  .section-link.current {
    background-color: var(--sl-color-black);
    color: var(--sl-color-white);
    font-weight: 600;
    box-shadow: 0 1px 2px oklch(0 0 0 / 6%);
  }

  .section-pages {
    list-style: none;
    margin: 1.25rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .section-pages a {
    display: block;
    padding: 0.32em 0.75em;
    font-size: 0.875rem;
    line-height: 1.55;
    text-decoration: none;
    color: var(--sl-color-gray-2);
    border-radius: 0.35rem;
    transition: color 0.15s;
  }

  .section-pages a:hover {
    color: var(--sl-color-white);
    background-color: var(--sl-color-gray-6);
  }
</style>
