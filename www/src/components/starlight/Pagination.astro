---
import { findCanonEntryByHref } from '@/lib/canon';

const { dir, pagination, locale } = Astro.locals.starlightRoute;
const { prev, next } = pagination;

const previousText = Astro.locals.t('page.previousLink');
const nextText = Astro.locals.t('page.nextLink');

interface PageLink {
  href: string;
  label: string;
}

async function enrich(link: PageLink | undefined) {
  if (!link) return undefined;
  const found = await findCanonEntryByHref(locale, link.href);
  return { ...link, number: found?.entry.number ?? '' };
}

const prevLink = await enrich(prev);
const nextLink = await enrich(next);
---

<nav class="canon-pagination print:hidden" dir={dir}>
  {
    prevLink && (
      <a href={prevLink.href} rel="prev" class="page-turn turn-prev">
        <span class="turn-label" aria-hidden="true">
          ← {previousText}
        </span>
        <span class="turn-title">
          {prevLink.number && <span class="turn-number">{prevLink.number}</span>}
          {prevLink.label}
        </span>
      </a>
    )
  }
  {
    nextLink && (
      <a href={nextLink.href} rel="next" class="page-turn turn-next">
        <span class="turn-label" aria-hidden="true">
          {nextText} →
        </span>
        <span class="turn-title">
          {nextLink.number && <span class="turn-number">{nextLink.number}</span>}
          {nextLink.label}
        </span>
      </a>
    )
  }
</nav>

<style>
  /* 翻篇：书页口的两枚指路 */
  .canon-pagination {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 1.5rem;
    margin-block-start: 3.5rem;
    padding-block-start: 1.4rem;
    border-block-start: 1px solid var(--sl-color-gray-5);
  }

  .page-turn {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    min-width: 0;
    text-decoration: none;
    color: inherit;
  }

  .turn-next {
    grid-column: 2;
    align-items: flex-end;
    text-align: end;
  }

  .turn-label {
    font-family: var(--font-ui);
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    color: var(--sl-color-gray-3);
  }

  .turn-title {
    font-size: 1.02rem;
    font-weight: 600;
    line-height: 1.55;
    color: var(--sl-color-gray-1);
    transition: color 0.15s;
  }

  .turn-number {
    margin-inline-end: 0.6em;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-cinnabar-500);
  }

  :root[data-theme='dark'] .turn-number {
    color: var(--color-cinnabar-400);
  }

  .page-turn:hover .turn-title {
    color: var(--color-cinnabar-600);
  }

  :root[data-theme='dark'] .page-turn:hover .turn-title {
    color: var(--color-cinnabar-300);
  }

  @media (max-width: 40rem) {
    .canon-pagination {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }

    .turn-next {
      grid-column: auto;
      align-items: flex-start;
      text-align: start;
    }
  }
</style>
