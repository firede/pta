---
import { RiArrowLeftLine, RiArrowRightLine } from '@remixicon/react';

import { buttonVariants } from '@/components/ui/button';
import { cn } from '@/lib/utils';

const { dir, pagination } = Astro.locals.starlightRoute;
const { prev, next } = pagination;
const isRtl = dir === 'rtl';

const previousText = Astro.locals.t('page.previousLink');
const nextText = Astro.locals.t('page.nextLink');
const navClass =
  'grid grid-cols-[minmax(0,1fr)_minmax(0,1fr)] items-center gap-2';
const linkClass = cn(
  buttonVariants({ variant: 'ghost', size: 'lg' }),
  'min-w-0 max-w-full no-underline text-muted-foreground hover:text-foreground max-[40rem]:size-9 max-[40rem]:gap-0 max-[40rem]:px-0 max-[40rem]:has-data-[icon=inline-start]:pl-0 max-[40rem]:has-data-[icon=inline-end]:pr-0',
);
const PreviousIcon = isRtl ? RiArrowRightLine : RiArrowLeftLine;
const NextIcon = isRtl ? RiArrowLeftLine : RiArrowRightLine;
---

<nav class={cn(navClass, 'print:hidden')} dir={dir} aria-label="页面导航">
  {
    prev && (
      <a
        href={prev.href}
        rel="prev"
        aria-label={`${previousText}: ${prev.label}`}
        class={cn(linkClass, 'justify-self-start')}
      >
        <PreviousIcon data-icon="inline-start" aria-hidden="true" />
        <span class="min-w-0 truncate max-[40rem]:hidden">{prev.label}</span>
      </a>
    )
  }
  {
    next && (
      <a
        href={next.href}
        rel="next"
        aria-label={`${nextText}: ${next.label}`}
        class={cn(linkClass, 'col-start-2 justify-self-end')}
      >
        <span class="min-w-0 truncate max-[40rem]:hidden">{next.label}</span>
        <NextIcon data-icon="inline-end" aria-hidden="true" />
      </a>
    )
  }
</nav>
