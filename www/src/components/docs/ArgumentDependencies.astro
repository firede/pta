---
import { getEntry } from 'astro:content';

import { getDocsEntryHref, getLocalizedDocsEntryId } from '@/lib/i18n';

interface Props {
  ids: readonly string[];
}

const { ids } = Astro.props;
const { locale } = Astro.locals.starlightRoute;
const titleId = 'argument-dependencies-title';

const dependencies = await Promise.all(
  ids.map(async (id) => {
    const entryId = getLocalizedDocsEntryId(id, locale);
    const entry = await getEntry('docs', entryId);

    if (!entry) {
      throw new Error(
        `ArgumentDependencies could not find docs entry "${entryId}" for source "${id}".`,
      );
    }

    return {
      sourceId: id,
      title: entry.data.title,
    };
  }),
);
---

{
  dependencies.length > 0 && (
    <section aria-labelledby={titleId} class="mt-8">
      <p
        id={titleId}
        class="mt-0! mb-2 font-heading text-sm font-semibold text-muted-foreground"
      >
        {Astro.locals.t('argumentDependencies.title')}
      </p>
      <ul class="my-0 list-disc ps-5">
        {
          dependencies.map((dependency) => (
            <li>
              <a href={getDocsEntryHref(dependency.sourceId, locale)}>{dependency.title}</a>
            </li>
          ))
        }
      </ul>
    </section>
  )
}
