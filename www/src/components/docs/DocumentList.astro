---
import { getEntry } from 'astro:content';
import { LinkCard } from '@astrojs/starlight/components';

import { getDocsEntryHref } from '@/lib/i18n';

interface Props {
  ids: readonly string[];
}

const { ids } = Astro.props;
const { locale } = Astro.locals.starlightRoute;

const entries = await Promise.all(
  ids.map(async (id) => {
    const entry = await getEntry('docs', id);

    if (!entry) {
      throw new Error(`DocumentList could not find docs entry "${id}".`);
    }

    return entry;
  }),
);
---

<div class="my-6 grid gap-4 *:mt-0!">
  {
    entries.map((entry) => (
      <LinkCard
        href={getDocsEntryHref(entry.id, locale)}
        title={entry.data.title}
        description={entry.data.description}
      />
    ))
  }
</div>
