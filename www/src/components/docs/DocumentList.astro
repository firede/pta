---
import { getEntry } from 'astro:content';
import { LinkCard } from '@astrojs/starlight/components';

import { getDocsEntryHref, getLocalizedDocsEntryId } from '@/lib/i18n';

interface Props {
  ids: readonly string[];
}

const { ids } = Astro.props;
const { locale } = Astro.locals.starlightRoute;

const documents = await Promise.all(
  ids.map(async (id) => {
    const entryId = getLocalizedDocsEntryId(id, locale);
    const entry = await getEntry('docs', entryId);

    if (!entry) {
      throw new Error(`DocumentList could not find docs entry "${entryId}" for source "${id}".`);
    }

    return {
      sourceId: id,
      title: entry.data.title,
      description: entry.data.description,
    };
  }),
);
---

<div class="my-6 grid gap-4 *:mt-0!">
  {
    documents.map((document) => (
      <LinkCard
        href={getDocsEntryHref(document.sourceId, locale)}
        title={document.title}
        description={document.description}
      />
    ))
  }
</div>
