{
  "name": "pta",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "pnpm run format:check && pnpm run lint && pnpm -r check",
    "ci": "pnpm run check && pnpm -r build",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "postinstall": "simple-git-hooks"
  },
  "devDependencies": {
    "nano-staged": "^1.0.2",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "simple-git-hooks": "^2.13.1"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec nano-staged"
  }
}
